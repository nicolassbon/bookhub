POSTGRES_DB=bookhub
POSTGRES_USER=bookhub_user
POSTGRES_PASSWORD=replace-with-local-postgres-password

SPRING_MAIL_HOST=localhost
SPRING_MAIL_PORT=2525
SPRING_MAIL_USERNAME=replace-with-local-mail-user
SPRING_MAIL_PASSWORD=replace-with-local-mail-password

JWT_ISSUER=bookhub-identity
JWT_AUDIENCE=bookhub-api
JWT_EXPIRATION=3600

# PKCS#8 RSA private key (2048 bits minimum)
JWT_RSA_PRIVATE_KEY='-----BEGIN PRIVATE KEY-----
PASTE_YOUR_LOCAL_PRIVATE_KEY_HERE
-----END PRIVATE KEY-----'

# X.509 RSA public key (matching the private key above)
JWT_RSA_PUBLIC_KEY='-----BEGIN PUBLIC KEY-----
PASTE_YOUR_LOCAL_PUBLIC_KEY_HERE
-----END PUBLIC KEY-----'

PASSWORD_RESET_HASH_SECRET=replace-with-local-password-reset-secret

REFRESH_TOKEN_EXPIRATION_SECONDS=604800
REFRESH_TOKEN_COOKIE_NAME=refresh_token
REFRESH_TOKEN_COOKIE_PATH=/api/v1/auth
REFRESH_TOKEN_COOKIE_SAME_SITE=Strict
REFRESH_TOKEN_COOKIE_SECURE=true
REFRESH_TOKEN_HASH_SECRET=replace-with-local-refresh-token-hash-secret

PASSWORD_RESET_EXPIRATION_SECONDS=900
PASSWORD_RESET_URL_BASE=https://bookhub.test/reset-password?token=
PASSWORD_RESET_FROM_ADDRESS=noreply@bookhub.test

AUTH_RATE_LIMIT_LOGIN_MAX_ATTEMPTS=10
AUTH_RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_REGISTER_MAX_ATTEMPTS=10
AUTH_RATE_LIMIT_REGISTER_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_FORGOT_PASSWORD_MAX_ATTEMPTS=10
AUTH_RATE_LIMIT_FORGOT_PASSWORD_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_REFRESH_MAX_ATTEMPTS=15
AUTH_RATE_LIMIT_REFRESH_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_TRUST_FORWARDED_HEADERS=false
AUTH_RATE_LIMIT_TRUSTED_PROXY_CIDRS=
AUTH_RATE_LIMIT_MAX_TRACKED_KEYS=10000
AUTH_RATE_LIMIT_STALE_ENTRY_TTL_SECONDS=600
