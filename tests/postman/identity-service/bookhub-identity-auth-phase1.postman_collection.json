              "const body = pm.response.json();",
              "pm.test('Login invalid length fields returns VALIDATION_ERROR', function () {",
              "  pm.expect(body.status).to.eql(400);",
              "  pm.expect(body.code).to.eql('VALIDATION_ERROR');",
              "});"
            ]
          }
        }
      ]
