        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"newPassword\": \"{{newPassword}}\"\n}"
        },
        "url": "{{baseUrl}}{{authBasePath}}/reset-password",
        "description": "Manual request: requires reset token from mail sink/logs.",
        "auth": {
          "type": "noauth"
        }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const resetToken = pm.environment.get('resetToken');",
              "pm.test('resetToken must be provided before reset-password', function () {",
              "  pm.expect(resetToken, 'Set resetToken in environment').to.be.a('string').and.not.empty;",
              "});"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Reset password returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const nextPassword = pm.environment.get('newPassword');",
              "if (nextPassword) {",
              "  pm.environment.set('testPassword', nextPassword);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "08 - Edge Case: Refresh missing cookie",
      "request": {
        "method": "POST",
        "header": [],
        "url": "{{baseUrl}}{{authBasePath}}/refresh",
        "description": "Missing refresh cookie must return 400/MISSING_REQUEST_COOKIE."
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.request.headers.remove('Cookie');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Refresh without cookie returns 400', function () {",
              "  pm.response.to.have.status(400);",
              "});",
              "const body = pm.response.json();",
              "pm.test('Refresh missing cookie error uses stable contract fields', function () {",
              "  pm.expect(body.status).to.eql(400);",
              "  pm.expect(body.code).to.eql('MISSING_REQUEST_COOKIE');",
              "});"
            ]
